# Variables de entorno para el Consultor de Continuidad Narrativa
# Copiar este archivo a .env y completar con tus credenciales

# Token de GitHub para acceso a GitHub Models API
GITHUB_TOKEN=tu_github_token_aqui

# URL base de la API (GitHub Models)
OPENAI_BASE_URL=https://models.inference.ai.azure.com

# URL opcional separada para embeddings (por defecto usa OPENAI_BASE_URL)
# OPENAI_EMBEDDINGS_URL=https://models.inference.ai.azure.com
